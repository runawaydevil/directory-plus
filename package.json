{
  "name": "directory-plus",
  "description": "Elegant retro Ghost theme for directories, pages, and curated links.",
  "version": "0.0.1",
  "license": "MIT",
  "author": {
    "name": "Pablo Murad",
    "email": "pablomurad@pm.me"
  },
  "keywords": [
    "ghost",
    "ghost-theme",
    "directory",
    "retro"
  ],
  "scripts": {
    "gscan": "gscan .",
    "zip": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package-theme.ps1"
  },
  "engines": {
    "ghost": ">=5.0.0"
  },
  "devDependencies": {
    "gscan": "latest"
  },
  "config": {
    "card_assets": true,
    "posts_per_page": 8,
    "custom": {
      "hero_video_url": {
        "type": "text",
        "group": "homepage",
        "description": "URL do video exibido no hero da home."
      }
    },
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 300
      },
      "m": {
        "width": 600
      },
      "l": {
        "width": 1000
      },
      "xl": {
        "width": 2000
      }
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
