<header class="site-header">
    <div class="header-frame">
        <a class="brand" href="{{@site.url}}">
            <span class="brand-mark">
                {{#if @site.logo}}
                    <img src="{{@site.logo}}" alt="{{@site.title}}">
                {{else}}
                    {{#if @site.icon}}
                        <img src="{{@site.icon}}" alt="{{@site.title}}">
                    {{else}}
                        <span>{{@site.title}}</span>
                    {{/if}}
                {{/if}}
            </span>

            <span class="brand-copy">
                <span class="brand-kicker">Retro Link Directory</span>
                <span class="brand-title">{{@site.title}}</span>
                {{#if @site.description}}
                    <span class="brand-description">{{@site.description}}</span>
                {{/if}}
            </span>
        </a>

        <div class="header-tools">
            {{#if @site.cover_image}}
                <div class="header-cover">
                    <img src="{{@site.cover_image}}" alt="{{@site.title}}">
                </div>
            {{/if}}

            <div class="header-nav-block">
                {{navigation}}
            </div>
        </div>
    </div>
</header>
