{{!< default}}

{{#post}}
    <article class="content-page {{post_class}}">
        {{#if @page.show_title_and_feature_image}}
            <header class="content-header">
                <p class="content-kicker">Página</p>
                <h1>{{title}}</h1>

                {{#if custom_excerpt}}
                    <p class="content-dek">{{custom_excerpt}}</p>
                {{/if}}
            </header>

            {{#if feature_image}}
                <figure class="content-figure">
                    <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
                    {{#if feature_image_caption}}
                        <figcaption>{{feature_image_caption}}</figcaption>
                    {{/if}}
                </figure>
            {{/if}}
        {{/if}}

        <div class="content-body">
            {{content}}
        </div>
    </article>
{{/post}}
