{{!< default}}

{{#author}}
    <header class="page-hero">
        <p class="section-kicker">Autor</p>
        <h1>{{name}}</h1>
        {{#if bio}}
            <p>{{bio}}</p>
        {{/if}}
    </header>
{{/author}}

<section class="section">
    <div class="section-heading">
        <div>
            <p class="section-kicker">Arquivo</p>
            <h2>Posts do autor</h2>
        </div>
        <p>Conteúdo organizado com o mesmo visual de diretório aplicado ao restante do tema.</p>
    </div>

    {{> "directory-feed"}}
</section>
