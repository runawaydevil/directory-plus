{{!< default}}

<section class="hero-stage">
    <div class="hero-copy">
        <p class="section-kicker">Directory Plus</p>
        <h1>{{@site.title}}</h1>
        {{#if @site.description}}
            <p class="hero-dek">{{@site.description}}</p>
        {{else}}
            <p class="hero-dek">Um espaço limpo, branco e direto para centralizar páginas, vídeos e presença editorial com estética IBM.</p>
        {{/if}}
    </div>

    <div class="hero-media">
        {{#if @custom.hero_video_url}}
            <video class="hero-video" autoplay muted loop playsinline poster="{{@site.cover_image}}">
                <source src="{{@custom.hero_video_url}}">
            </video>
        {{else}}
            {{#if @site.cover_image}}
                <img class="hero-poster" src="{{@site.cover_image}}" alt="{{@site.title}}">
            {{else}}
                <div class="hero-placeholder">
                    <span class="eyebrow">Hero Video</span>
                    <p>Adicione a URL do video em Design &amp; branding do tema para preencher esta area.</p>
                </div>
            {{/if}}
        {{/if}}
    </div>
</section>
